<Window x:Class="NeonPdfShot.DotNet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NeonPDF Shot (.NET)"
        Width="980"
        Height="720"
        MinWidth="880"
        MinHeight="640"
        Background="{StaticResource WindowBrush}">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,10">
            <TextBlock Text="PDF to JPG Converter"
                       FontSize="34"
                       FontWeight="Bold"
                       Foreground="#FFFFFFFF" />
            <TextBlock Text="Windows native (.NET 8) drag-and-drop converter for enterprise environments"
                       Foreground="#FFB7D6FF"
                       FontSize="14" />
        </StackPanel>

        <Border Grid.Row="1"
                x:Name="DropZone"
                Height="210"
                CornerRadius="16"
                BorderThickness="2"
                BorderBrush="#FF62A8FF"
                Background="#22163C67"
                AllowDrop="True"
                Drop="DropZone_Drop"
                DragOver="DropZone_DragOver"
                DragLeave="DropZone_DragLeave"
                Margin="0,0,0,14">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Drop PDF files here"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#FFE9F4FF"
                           HorizontalAlignment="Center" />
                <TextBlock Text="or use Select PDF Files"
                           Margin="0,8,0,0"
                           FontSize="15"
                           Foreground="#FFC8E1FF"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Multiple PDFs supported"
                           Margin="0,5,0,0"
                           FontSize="12"
                           Foreground="#FF94BCF0"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                CornerRadius="12"
                Padding="14"
                Margin="0,0,0,14"
                BorderBrush="#6682B6EA"
                BorderThickness="1"
                Background="#1E10243E">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="140" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="Output Folder" Foreground="#FFD0E6FF" VerticalAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="1" x:Name="OutputFolderText" TextWrapping="Wrap" Foreground="#FFEAF4FF" />
                <Button Grid.Row="0" Grid.Column="2" Content="Choose" Click="ChooseOutput_Click" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,10,0,0" Text="DPI" Foreground="#FFD0E6FF" VerticalAlignment="Center" />
                <TextBox Grid.Row="1" Grid.Column="1"
                         Margin="0,10,0,0"
                         x:Name="DpiTextBox"
                         Text="200"
                         Width="140"
                         HorizontalAlignment="Left"
                         Padding="8,6"
                         BorderThickness="1"
                         BorderBrush="#6688B6EA"
                         Background="#CC091A33"
                         Foreground="#FFF0F8FF" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,10,0,0" Text="JPG Quality" Foreground="#FFD0E6FF" VerticalAlignment="Center" />
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,10,0,0">
                    <Slider x:Name="QualitySlider"
                            Minimum="40"
                            Maximum="100"
                            Value="90"
                            Width="240"
                            ValueChanged="QualitySlider_ValueChanged" />
                    <TextBlock x:Name="QualityValueText"
                               Text="90"
                               Margin="12,0,0,0"
                               Foreground="#FFEAF4FF"
                               VerticalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Margin="0,0,8,0"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#6682B6EA"
                    BorderThickness="1"
                    Background="#1A0E223E">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Selected PDFs"
                               Margin="0,0,0,10"
                               Foreground="#FFDBEBFF"
                               FontWeight="SemiBold" />
                    <ListBox x:Name="PdfList"
                             BorderThickness="0"
                             Foreground="#FFEAF4FF"
                             Background="#00112233" />
                </DockPanel>
            </Border>

            <Border Grid.Column="1"
                    Margin="8,0,0,0"
                    CornerRadius="12"
                    Padding="12"
                    BorderBrush="#6682B6EA"
                    BorderThickness="1"
                    Background="#1A0E223E">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="Conversion Log"
                               Margin="0,0,0,10"
                               Foreground="#FFDBEBFF"
                               FontWeight="SemiBold" />
                    <TextBox x:Name="LogText"
                             IsReadOnly="True"
                             BorderThickness="0"
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             Foreground="#FFEAF4FF"
                             Background="#00112233" />
                </DockPanel>
            </Border>
        </Grid>

        <StackPanel Grid.Row="4" Margin="0,14,0,0">
            <ProgressBar x:Name="ProgressBar"
                         Height="20"
                         Minimum="0"
                         Maximum="100"
                         Value="0"
                         Foreground="#FF31D3B7"
                         Background="#55071932" />
            <StackPanel Orientation="Horizontal" Margin="0,10,0,0" HorizontalAlignment="Left">
                <Button Content="Select PDF Files" Click="SelectFiles_Click" />
                <Button Content="Clear List" Click="ClearFiles_Click" />
                <Button x:Name="ConvertButton" Content="Convert to JPG" Click="Convert_Click" />
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
