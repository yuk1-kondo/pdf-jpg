<Application x:Class="NeonPdfShot.DotNet.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <LinearGradientBrush x:Key="WindowBrush" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FF050A1D" Offset="0" />
            <GradientStop Color="#FF102B4E" Offset="0.55" />
            <GradientStop Color="#FF07172E" Offset="1" />
        </LinearGradientBrush>

        <Style TargetType="Button">
            <Setter Property="Foreground" Value="#FFF7FBFF" />
            <Setter Property="Background" Value="#FF2167D8" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border CornerRadius="9" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF3889FF" />
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#FF4B5D7E" />
                    <Setter Property="Foreground" Value="#FFBFCBE4" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
